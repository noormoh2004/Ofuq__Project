<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/backgroundhome"
    android:orientation="vertical"
    >

    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        >

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/girlbg"
            android:layout_marginTop="20dp"
            android:layout_marginLeft="10dp"
            >

        </ImageView>

        <TextView
        android:id="@+id/texthello"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="مرحبا بك يا نور"
        android:textSize="35sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_marginTop="50dp"
        android:layout_marginLeft="120dp"
        >
    </TextView>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="كيف تشعر اليوم؟"
        android:textSize="25sp"
        android:layout_below="@+id/texthello"
        android:layout_centerHorizontal="true"
        android:textColor="@color/white"
        >
    </TextView>
</RelativeLayout>


    <LinearLayout
        android:id="@+id/feelings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/login_card_bg"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:paddingRight="2dp"
        >

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            >

       <ImageView
           android:layout_width="70dp"
           android:layout_height="70dp"
           android:src="@drawable/happy"
           android:layout_marginTop="7dp"
           >
       </ImageView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="سعيد"
                android:textSize="25sp"
                android:layout_marginTop="3dp"
                android:textColor="@color/white"
                android:layout_marginLeft="20dp"

                >

            </TextView>
</LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            >

            <ImageView
                android:layout_width="75dp"
                android:layout_height="75dp"
                android:src="@drawable/calm"
                android:layout_marginTop="5dp"
                android:layout_marginLeft="5dp"
                android:padding="0dp"
                >
            </ImageView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="هادئ"
                android:textSize="25sp"
                android:layout_marginTop="3dp"
                android:textColor="@color/white"
                android:layout_marginLeft="20dp"
                >

            </TextView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="10dp"
            >

            <ImageView
                android:layout_width="75dp"
                android:layout_height="75dp"
                android:src="@drawable/sad"
                android:layout_marginTop="8dp"
                android:padding="0dp"
                >
            </ImageView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="حزين"
                android:textSize="25sp"
                android:textColor="@color/white"
                android:layout_marginLeft="20dp"
                >

            </TextView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="10dp"
            >

            <ImageView
                android:layout_width="75dp"
                android:layout_height="75dp"
                android:src="@drawable/scared"
                android:layout_marginTop="5dp"
                android:padding="0dp"
                >
            </ImageView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="خائف"
                android:textSize="25sp"
                android:layout_marginTop="4dp"
                android:textColor="@color/white"
                android:layout_marginLeft="20dp"
                >

            </TextView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="10dp"
            >

            <ImageView
                android:layout_width="75dp"
                android:layout_height="75dp"
                android:src="@drawable/angry"
                android:layout_marginTop="8dp"
                android:padding="0dp"
                >
            </ImageView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="غاضب"
                android:textSize="25sp"
                android:textColor="@color/white"
                android:layout_marginLeft="20dp"
                >

            </TextView>
        </LinearLayout>

    </LinearLayout>


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        >
        <LinearLayout
            android:layout_width="200dp"
            android:layout_height="400dp"
            android:background="@drawable/backgroundcard1"
            android:layout_marginTop="20dp"
            android:layout_marginLeft="5dp"
            android:orientation="vertical"
            >
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="عبّر عن مشاعرك "
                android:textStyle="bold"
                android:textSize="22dp"
                android:layout_marginTop="10dp"
                android:textColor="@color/purple"
                android:gravity="center"
                >
            </TextView>
            <TextView
                android:layout_width="120dp"
                android:layout_height="50dp"
                android:text="طرق مختلفة تساعدك على التعبير عن نفسك"
                android:textColor="@color/gray"
                android:layout_gravity="center"
                android:textStyle="bold"
                >

            </TextView>
            <ImageView
                android:layout_width="150dp"
                android:layout_height="120dp"
                android:src="@drawable/bgcard1"
                android:layout_gravity="center"

                >
            </ImageView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:orientation="vertical"
                    >
                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/cub"
                        >

                    </ImageView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="تحدث"
                        android:textSize="25dp"
                        >
                    </TextView>


                </LinearLayout>


                <LinearLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:orientation="vertical"
                    >
                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/logo2"
                        >

                    </ImageView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ارسم"
                        android:textSize="25dp"
                        >
                    </TextView>


                </LinearLayout>


                <LinearLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:orientation="vertical"
                    >
                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/logo2"
                        >

                    </ImageView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="يومياتي"
                        android:textSize="25dp"
                        >
                    </TextView>


                </LinearLayout>
                <Button
                    android:id="@+id/btnStart"
                    android:layout_width="300dp"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:text="ايدأ الان"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:padding="0dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_centerHorizontal="true"
                    android:textSize="25sp"
                    android:layout_below="@+id/login_section"
                    android:backgroundTint="@color/purple"
                    android:elevation="8dp"
                    android:translationZ="4dp"
                    android:stateListAnimator="@null"
                    >
                </Button>


            </LinearLayout>










        </LinearLayout>


        <LinearLayout
            android:layout_width="200dp"
            android:layout_height="400dp"
            android:background="@drawable/backgroundcard2"
            android:layout_marginTop="20dp"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:orientation="vertical"
            >
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="واحة المرح والقراءة "
                android:textStyle="bold"
                android:textSize="22dp"
                android:layout_marginTop="10dp"
                android:textColor="@color/purple"
                android:gravity="center"
                >
            </TextView>

            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="قصص جميلة, حزازير ذكية وأوسمة تنتظرك"
                android:layout_gravity="center"
                android:textColor="@color/gray"
                android:textStyle="bold">

            </TextView>
            <ImageView
                android:layout_width="200dp"
                android:layout_height="120dp"
                android:src="@drawable/bgcard2"
                android:layout_gravity="center_horizontal">

            </ImageView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:layout_marginHorizontal="10dp"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    >

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp">

                    </ImageView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="قصص مشوقة"
                        >

                    </TextView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        >

                    </TextView>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    >

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp">

                    </ImageView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="حزازير ذكية"
                        >

                    </TextView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        >

                    </TextView>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    >

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp">

                    </ImageView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="لوحة الأوسمة"
                        >

                    </TextView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        >

                    </TextView>

                </LinearLayout>
            </LinearLayout>
            <Button
                android:id="@+id/explore"
                android:layout_width="300dp"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:text="استكشف الان"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:padding="0dp"
                android:layout_gravity="center_horizontal"
                android:layout_centerHorizontal="true"
                android:textSize="25sp"
                android:layout_below="@+id/login_section"
                android:backgroundTint="@color/purple"
                android:elevation="8dp"
                android:translationZ="4dp"
                android:stateListAnimator="@null"
                >
            </Button>



        </LinearLayout>



    </LinearLayout>



</LinearLayout>

