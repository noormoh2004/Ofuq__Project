<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/backgroundhome"
    android:orientation="vertical"
    >


    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        >

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/girl"
            android:layout_marginTop="20dp"
            android:layout_marginLeft="10dp">

        </ImageView>

        <TextView
        android:id="@+id/texthello"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="مرحبا بك يا نور"
        android:textSize="35sp"
        android:textStyle="bold"
        android:textColor="@color/purple"
        android:layout_marginTop="50dp"
        android:layout_marginLeft="120dp"
        >
    </TextView>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="كيف تشعر اليوم؟"
        android:textSize="25sp"
        android:layout_below="@+id/texthello"
        android:layout_centerHorizontal="true"
        android:textColor="@color/purple"
        >
    </TextView>
</RelativeLayout>


    <LinearLayout
        android:id="@+id/feelings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/login_card_bg"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:paddingRight="2dp"
        >

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="10dp"
            >

       <ImageView
           android:layout_width="65dp"
           android:layout_height="65dp"
           android:src="@drawable/happysmile"
           android:layout_marginTop="7dp"

           >
       </ImageView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="سعيد"
                android:textSize="25sp"
                android:textStyle="bold"
                android:layout_marginTop="7dp"
                android:textColor="@color/black"
                android:layout_marginLeft="015dp"

                >

            </TextView>
</LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            >

            <ImageView
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:src="@drawable/calmsmile"
                android:layout_marginTop="7dp"
                android:layout_marginLeft="5dp"
                android:padding="0dp"
                >
            </ImageView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="هادئ"
                android:textSize="25sp"
                android:textStyle="bold"
                android:layout_marginTop="3dp"
                android:textColor="@color/black"
                android:layout_marginLeft="20dp"
                >

            </TextView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="10dp"
            >

            <ImageView
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:src="@drawable/sadsmile"
                android:layout_marginTop="7dp"
                android:padding="0dp"
                >
            </ImageView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="حزين"
                android:textSize="25sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginLeft="15dp"
                android:layout_marginTop="3dp"
                >

            </TextView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="10dp"
            >

            <ImageView
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/scaredsmile"
                android:layout_marginTop="5dp"
                android:padding="0dp"
                >
            </ImageView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="خائف"
                android:textSize="25sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:textColor="@color/black"
                android:layout_marginLeft="15dp"
                >

            </TextView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="10dp"
            >

            <ImageView
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/angrysmile"
                android:layout_marginTop="5dp"
                android:padding="0dp"
                >
            </ImageView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="غاضب"
                android:textSize="25sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginLeft="12dp"
                android:layout_marginTop="3dp"
                >

            </TextView>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        >
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="اضغط على شعورك لتبدأ رحلتك معنا اليوم"
            android:textSize="25sp"
            android:textStyle="bold"
            android:textColor="@color/purple"
            android:gravity="center"

            >

        </TextView>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:gravity="center"
        android:orientation="vertical"
        >
        <LinearLayout
            android:layout_width="360dp"
            android:layout_height="120dp"
            android:background="@drawable/login_card_bg"
            android:orientation="vertical"
            android:layout_marginBottom="0dp"

            >

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"

                >

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/draw"
                android:layout_marginTop="10dp"

                >

            </ImageView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="عالم التعبير"
                android:textSize="35sp"
                android:textColor="@color/purple"
                android:layout_gravity="center_horizontal">

            </TextView>

                </LinearLayout>

            <Button
                android:id="@+id/start"
                android:layout_width="190dp"
                android:layout_height="43dp"
                android:text="ابدأ الآن"
                android:layout_gravity="center"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:padding="0dp"
                android:layout_marginBottom="0dp"
                android:textSize="25sp"
                android:backgroundTint="@color/purple"
                android:elevation="8dp"
                android:translationZ="4dp"
                android:stateListAnimator="@null">

            </Button>
        </LinearLayout>



        <LinearLayout
            android:layout_width="360dp"
            android:layout_height="120dp"
            android:background="@drawable/login_card_bg"
            android:orientation="vertical"
            android:layout_marginTop="15dp"

            >

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal">


                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:src="@drawable/book">

                </ImageView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="عالم القراءة والمرح "
                    android:textColor="@color/purple"
                    android:textSize="30sp">

                </TextView>
            </LinearLayout>
            <Button
                android:id="@+id/explore"
                android:layout_width="190dp"
                android:layout_height="43dp"
                android:text="استكشف الان"
                android:layout_gravity="center"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:padding="0dp"
                android:textSize="25sp"
                android:backgroundTint="@color/purple"
                android:elevation="8dp"
                android:translationZ="4dp"
                android:stateListAnimator="@null">

            </Button>

                </LinearLayout>







            </LinearLayout>






        </LinearLayout>












